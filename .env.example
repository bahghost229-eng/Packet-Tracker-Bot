# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Helius RPC HTTP + WSS (recommandé pour Solana)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_HTTP=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_RPC_WSS=wss://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Fallback RPC (QuickNode ou public)
FALLBACK_RPC_HTTP=https://api.mainnet-beta.solana.com
FALLBACK_RPC_WSS=wss://api.mainnet-beta.solana.com

# ID Telegram des admins autorisés (séparés par virgule)
ALLOWED_USER_IDS=123456789,987654321

# Niveau de log: error | warn | info | debug
LOG_LEVEL=info

# Chemin de la base SQLite
DB_PATH=./data/tracker.db

# Délai max en ms pour le suivi de chaîne par hop (évite les boucles infinies)
CHAIN_HOP_TIMEOUT_MS=30000

# Reconnexion WebSocket: délai initial (ms)
WS_RECONNECT_DELAY_MS=3000
